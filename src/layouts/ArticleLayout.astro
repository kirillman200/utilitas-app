---
import BaseLayout from './BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { SITE, absolute, projects } from '../data/site';
import { articlePath, articles, type ArticleDefinition } from '../data/articles';

interface Props { article: ArticleDefinition }
const { article } = Astro.props;
const path = articlePath(article);
const project = projects.find((item) => item.slug === article.relatedProject);
const related = articles
  .filter((item) => item.slug !== article.slug && (item.topic === article.topic || item.relatedProject === article.relatedProject))
  .slice(0, 2);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    description: article.description,
    datePublished: article.published,
    dateModified: article.updated,
    inLanguage: 'en-CA',
    mainEntityOfPage: absolute(path),
    author: { '@type': 'Organization', name: SITE.name, url: SITE.origin },
    publisher: { '@type': 'Organization', name: SITE.name, url: SITE.origin },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.origin },
      { '@type': 'ListItem', position: 2, name: 'Field Notes', item: absolute('/articles/') },
      { '@type': 'ListItem', position: 3, name: article.shortTitle, item: absolute(path) },
    ],
  },
];
---

<BaseLayout
  title={`${article.title} | Utilitas`}
  description={article.description}
  path={path}
  schema={schema}
  ogType="article"
  published={article.published}
  updated={article.updated}
>
  <article class="article-page">
    <header class="article-hero">
      <div class="shell article-hero-grid">
        <div class="article-rail" aria-label="Article details">
          <a href="/articles/">Field Notes</a>
          <span>Topic: {article.topic}</span>
          <span>{article.readTime}</span>
          <span>Updated {article.updated}</span>
        </div>
        <div class="article-title">
          <p class="kicker">Practical method / {article.topic}</p>
          <h1>{article.title}</h1>
          <p class="article-intro">{article.intro}</p>
        </div>
      </div>
    </header>

    <div class="shell article-body-grid">
      <aside class="article-toc" aria-label="On this page">
        <p>On this page</p>
        {article.sections.map((section, index) => (
          <a href={`#section-${index + 1}`}>{String(index + 1).padStart(2, '0')} {section.heading}</a>
        ))}
      </aside>
      <div class="article-content">
        {article.sections.map((section, index) => (
          <section id={`section-${index + 1}`}>
            <p class="section-number">{String(index + 1).padStart(2, '0')}</p>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}
            {section.note && <aside class="method-note"><strong>Method note</strong><p>{section.note}</p></aside>}
          </section>
        ))}

        <section class="takeaway-block" aria-labelledby="takeaway-title">
          <p class="section-number">Summary</p>
          <h2 id="takeaway-title">What to carry forward</h2>
          <ol>{article.takeaways.map((takeaway) => <li>{takeaway}</li>)}</ol>
        </section>

        {project && project.url && (
          <aside class="article-tool-link">
            <div>
              <p class="kicker">Related browser tool</p>
              <h2>{project.name}</h2>
              <p>{project.description}</p>
            </div>
            <a class="button button-light" href={project.url} rel="external">Open {project.name} <span aria-hidden="true">&nearr;</span></a>
          </aside>
        )}
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="related-notes section-pad">
      <div class="shell">
        <div class="section-heading compact-heading">
          <div><p class="kicker">Continue reading</p><h2>Related field notes</h2></div>
          <a class="text-link" href="/articles/">View all notes <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="notes-list">{related.map((item, index) => <ArticleRow article={item} index={index} />)}</div>
      </div>
    </section>
  )}
</BaseLayout>
