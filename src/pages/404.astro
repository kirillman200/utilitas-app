---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Utilitas"
  description="The requested Utilitas page could not be found."
  path="/404/"
  robots="noindex, follow"
>
  <section class="not-found">
    <div class="shell not-found-inner">
      <p class="error-code">404</p>
      <p class="eyebrow">This path came up empty</p>
      <h1>That page is not on the shelf</h1>
      <p>Return to the collection or browse every available project.</p>
      <div class="hero-actions">
        <a class="button" href="/">Go home</a>
        <a class="text-link" href="/projects/">Browse projects <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
