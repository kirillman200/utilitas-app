---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { SITE, projects, absolute } from '../data/site';
import { articles } from '../data/articles';

const liveProjects = projects.filter((project) => project.status === 'live');
const liveToolCount = String(liveProjects.length).padStart(2, '0');
const fieldNoteCount = String(articles.length).padStart(2, '0');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.origin,
    description: SITE.description,
    inLanguage: 'en-CA',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.origin,
    description: SITE.shortDescription,
    sameAs: [SITE.ownerUrl],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Utilitas browser tools and field notes',
    url: SITE.origin,
    description: SITE.description,
    hasPart: [
      ...projects.map((project) => ({ '@type': 'SoftwareApplication', name: project.name, url: project.url })),
      { '@type': 'CollectionPage', name: 'Utilitas Field Notes', url: absolute('/articles/') },
    ],
  },
];
---

<BaseLayout title={SITE.title} description={SITE.description} path="/" schema={schema}>
  <section class="home-hero">
    <div class="hero-ticker" aria-hidden="true">
      <span>CREATE</span><span>PLAN</span><span>PROTECT</span><span>UNDERSTAND</span><span>CREATE</span>
    </div>
    <div class="shell hero-stage">
      <div class="hero-sequence" aria-hidden="true">
        <span>U</span><span>/</span><span>01</span>
      </div>
      <div class="hero-copy">
        <p class="kicker">Focused browser utilities / Direct access</p>
        <h1>Useful tools for work that <em>stays yours.</em></h1>
        <p class="hero-lede">Edit vectors, plan materials, protect photos, and take on more practical browser work as the collection grows. Each tool has one clear job, no required account, and a plain-language data boundary.</p>
        <div class="hero-actions">
          <a class="button" href="/projects/">Open the tool index <span aria-hidden="true">&rarr;</span></a>
          <a class="text-link" href="/articles/">Read Field Notes <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
      <div class="hero-console" aria-label="Utilitas operating principles">
        <div class="console-head"><span>UTILITY REGISTER</span><span>STATUS / LIVE</span></div>
        <dl>
          <div><dt>01</dt><dd><strong>Browser first</strong><span>Work where the task happens</span></dd></div>
          <div><dt>02</dt><dd><strong>Explicit limits</strong><span>Assumptions stay visible</span></dd></div>
          <div><dt>03</dt><dd><strong>Local by design</strong><span>Files stay on your device where practical</span></dd></div>
        </dl>
        <p>NO ACCOUNT / NO HUB UPLOADS / DIRECT ACCESS</p>
      </div>
    </div>
  </section>

  <section class="tool-index section-pad">
    <div class="shell">
      <div class="section-heading">
        <div><p class="kicker">Tool index / {liveToolCount} live</p><h2>Choose the work,<br />then enter the tool.</h2></div>
        <p>These are separate products, not skins of the same app. Each keeps the interface, documentation, and privacy language needed for its specific job.</p>
      </div>
      <div class="tool-ledger">
        {liveProjects.map((project, index) => (
          <article class={`tool-ledger-row accent-${project.accent}`}>
            <p class="ledger-number">{String(index + 1).padStart(2, '0')}</p>
            <div class="ledger-name">
              <p>{project.eyebrow}</p>
              <h3>{project.name}</h3>
            </div>
            <p class="ledger-description">{project.description}</p>
            <div class="ledger-action">
              <span>{project.domainLabel}</span>
              {project.url && <a href={project.url} rel="external" aria-label={`Open ${project.name}`}>Launch <span aria-hidden="true">&nearr;</span></a>}
            </div>
          </article>
        ))}
      </div>
      <div class="index-action"><a class="button button-ghost" href="/projects/">Compare all capabilities <span aria-hidden="true">&rarr;</span></a></div>
    </div>
  </section>

  <section class="system-statement">
    <div class="shell statement-grid">
      <p class="statement-code">WHY / UTILITAS</p>
      <h2>Software should explain itself before it asks for trust.</h2>
      <div class="statement-copy">
        <p>Utilitas tools foreground the task, the assumptions, and the data boundary. The hub has no account system or upload feature. Individual products state their own storage and sharing behavior where it matters.</p>
        <a class="text-link inverse" href="/about/">Read the operating principles <span aria-hidden="true">&rarr;</span></a>
      </div>
      <div class="statement-metrics" aria-label="Utilitas collection facts">
        <div><strong>{liveToolCount}</strong><span>live tools</span></div>
        <div><strong>{fieldNoteCount}</strong><span>field notes</span></div>
        <div><strong>00</strong><span>accounts required</span></div>
      </div>
    </div>
  </section>

  <section class="field-notes-preview section-pad">
    <div class="shell">
      <div class="section-heading compact-heading">
        <div><p class="kicker">Field Notes / Edition 01</p><h2>Methods behind the tools</h2></div>
        <a class="text-link" href="/articles/">Browse all {articles.length} guides <span aria-hidden="true">&rarr;</span></a>
      </div>
      <div class="notes-list">{articles.slice(0, 4).map((article, index) => <ArticleRow article={article} index={index} />)}</div>
    </div>
  </section>

  <section class="home-close">
    <div class="shell close-grid">
      <p class="kicker">Start with a useful outcome</p>
      <h2>Make. Measure. Check. Share.</h2>
      <div><p>Open a focused tool or learn the method first. No sign-up stands between you and the work.</p><a class="button button-light" href="/projects/">Browse live tools <span aria-hidden="true">&rarr;</span></a></div>
    </div>
  </section>
</BaseLayout>
