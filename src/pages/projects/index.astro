---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, projects } from '../../data/site';

const title = 'Projects | Utilitas';
const description = 'Explore every live Utilitas browser tool for creating, planning, and protecting everyday work.';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Utilitas projects',
  url: `${SITE.origin}/projects/`,
  description,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: projects.length,
    itemListElement: projects.map((project, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: project.name,
      description: project.description,
      url: project.url,
    })),
  },
};
---

<BaseLayout title={title} description={description} path="/projects/" schema={schema}>
  <section class="registry-hero">
    <div class="shell registry-hero-grid">
      <div>
        <p class="kicker">Utilitas tool registry / Live index</p>
        <h1>Three tools.<br />Three clear jobs.</h1>
      </div>
      <div class="registry-intro">
        <p>Open the product that matches the work. Each tool has its own production domain, focused interface, and product-specific privacy boundary.</p>
        <div class="registry-status"><span aria-hidden="true"></span> All listed tools are live</div>
      </div>
    </div>
  </section>

  <section class="project-registry">
    {projects.map((project, index) => (
      <article class={`registry-entry registry-${project.accent}`}>
        <div class="shell registry-entry-grid">
          <div class="registry-id"><span>{String(index + 1).padStart(2, '0')}</span><span>{project.category.toUpperCase()}</span></div>
          <div class="registry-main">
            <p class="kicker">{project.eyebrow}</p>
            <h2>{project.name}</h2>
            <p>{project.description}</p>
            {project.url && <a class="button" href={project.url} rel="external">Open live tool <span aria-hidden="true">&nearr;</span></a>}
          </div>
          <div class="registry-spec">
            <p>Core capabilities</p>
            <ul>{project.features.map((feature) => <li>{feature}</li>)}</ul>
          </div>
          <div class="registry-boundary">
            <p>Data boundary</p>
            <p>{project.privacy}</p>
            <span>{project.domainLabel}</span>
          </div>
        </div>
      </article>
    ))}
  </section>

  <section class="registry-foot section-pad">
    <div class="shell registry-foot-grid">
      <p class="kicker">One collection, independent products</p>
      <h2>The hub is an index, not an account dashboard.</h2>
      <div><p>No login is required here. Following a launch link moves to the selected product and its own policies.</p><a class="text-link" href="/privacy/">Review the hub privacy boundary <span aria-hidden="true">&rarr;</span></a></div>
    </div>
  </section>
</BaseLayout>
