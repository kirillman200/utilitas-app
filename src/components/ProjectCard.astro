---
import type { ProjectDefinition } from '../data/site';
import { statusLabel } from '../data/site';

interface Props { project: ProjectDefinition; featured?: boolean }
const { project, featured = false } = Astro.props;
---

<article class:list={['project-card', `accent-${project.accent}`, { featured }]}>
  <div class="project-topline">
    <span class="project-mark" aria-hidden="true">{project.monogram}</span>
    <span class:list={['status', { live: project.status === 'live' }]}>
      <i aria-hidden="true"></i>{statusLabel(project.status)}
    </span>
  </div>
  <p class="eyebrow">{project.eyebrow}</p>
  <h3>{project.name}</h3>
  <p>{project.description}</p>
  <ul class="feature-chips" aria-label={`${project.name} highlights`}>
    {project.features.slice(0, featured ? 4 : 3).map((feature) => <li>{feature}</li>)}
  </ul>
  <div class="project-card-footer">
    {project.url ? (
      <a class="text-link" href={project.url} rel="external">Open {project.name} <span aria-hidden="true">↗</span></a>
    ) : (
      <span class="availability">Production link will appear after launch</span>
    )}
    {project.url && project.domainLabel && <span class="domain-label">{project.domainLabel}</span>}
  </div>
</article>
