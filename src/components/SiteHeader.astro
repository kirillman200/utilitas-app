---
import { SITE, projects } from '../data/site';

const pathname = Astro.url.pathname;
const liveToolCount = projects.filter((project) => project.status === 'live').length;
const links = [
  { href: '/projects/', label: 'Tools' },
  { href: '/articles/', label: 'Field Notes' },
  { href: '/about/', label: 'About' },
];
const isCurrent = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label={`${SITE.name} home`}>
      <span class="brand-mark" aria-hidden="true">U/</span>
      <span class="brand-name">{SITE.name}</span>
      <span class="brand-tag">Useful by design</span>
    </a>
    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map((link) => <a href={link.href} aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a>)}
      <a class="nav-index" href="/projects/">{liveToolCount} live <span aria-hidden="true">&nearr;</span></a>
    </nav>
    <details class="mobile-menu">
      <summary aria-label="Open navigation"><span></span><span></span><span></span></summary>
      <nav aria-label="Mobile navigation">
        <a href="/">Home</a>
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
        <a href="/privacy/">Privacy</a>
        <a href="/contact/">Contact</a>
      </nav>
    </details>
  </div>
</header>
