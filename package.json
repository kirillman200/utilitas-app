{
  "name": "utilitas-app",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "description": "The main home for focused, privacy-conscious browser utilities from Utilitas.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "test": "npm run test:site",
    "test:site": "vitest run tests/site-contract.test.ts tests/worker.test.ts",
    "validate": "npm run check && npm run build && npm run test:site",
    "deploy:dry": "npm run validate && wrangler deploy --dry-run",
    "deploy": "npm run validate && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/vue": "^7.0.1",
    "astro": "^7.1.3",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
